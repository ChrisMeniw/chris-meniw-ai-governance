    "alternateName": "Christian Walter Meniw",
    "honorificSuffix": "Dr. h.c.",
    "jobTitle": "研究者、律师、创始人兼首席执行官",
    "url": "https://www.chrismeniwfoundation.org",
    "sameAs": [
      "https://orcid.org/0009-0003-4417-1944",
